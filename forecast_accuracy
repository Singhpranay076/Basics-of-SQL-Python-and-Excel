   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "8858ca35-9c61-4343-8b25-cbb80d1cc41a",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv(\"accu_fcast.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "85f4ff96-a88e-4d44-980a-fe856769076e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Add the Error columns (Day 2 requirement)\n",
    "df['Error_3MA'] = df['Actual_Demand'] - df['3MA_Forecast']\n",
    "df['Error_ES']  = df['Actual_Demand'] - df['ES_Forecast']\n",
    "\n",
    "# Add APE (% Error) columns\n",
    "df['APE_3MA'] = (df['Error_3MA'].abs() / df['Actual_Demand']) * 100\n",
    "df['APE_ES']  = (df['Error_ES'].abs() / df['Actual_Demand']) * 100"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "d5478ac7-5c4e-4116-ba7c-718a18213dd2",
   "metadata": {},
   "outputs": [],
   "source": [
    "#  Calculate metrics (correct ranges)\n",
    "valid_3ma = df.iloc[3:12]          # Only April–Dec for 3MA\n",
    "\n",
    "metrics = {\n",
    "    \"Model\": [\"3MA (3-month Moving Avg)\", \"ES (Exponential Smoothing α=0.5)\"],\n",
    "    \"MAPE (%)\": [valid_3ma['APE_3MA'].mean(), df['APE_ES'].mean()],\n",
    "    \"Bias\": [valid_3ma['Error_3MA'].mean(), df['Error_ES'].mean()],\n",
    "    \"Std. Dev. of Errors\": [valid_3ma['Error_3MA'].std(), df['Error_ES'].std()]\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "03014dd4-580a-45a1-af55-861cebc0d655",
   "metadata": {},
   "outputs": [],
   "source": [
    "metrics_df = pd.DataFrame(metrics)\n",
    "\n",
    "# 5. Add Recommendation (Best model)\n",
    "metrics_df['Recommendation'] = [\n",
    "    \"Decent, but higher error\",\n",
    "    \"**BEST MODEL** – lowest MAPE + more consistent\"\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "391792ef-9afd-4655-bdd3-1f35e5120e53",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Here are your correct metrics:\n",
      "   index                             Model  MAPE (%)  Bias  \\\n",
      "0      0          3MA (3-month Moving Avg)     22.25  3.33   \n",
      "1      1  ES (Exponential Smoothing α=0.5)     15.02  4.32   \n",
      "\n",
      "   Std. Dev. of Errors                                  Recommendation  \n",
      "0                40.72                        Decent, but higher error  \n",
      "1                29.78  **BEST MODEL** – lowest MAPE + more consistent  \n"
     ]
    }
   ],
   "source": [
    "# Show results\n",
    "print(\"Here are your correct metrics:\")\n",
    "print(metrics_df.round(2).reset_index())"
   ]
  },
